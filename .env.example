# Lunar Tools Art Prototypes - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key for text generation and TTS
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API Token for image generation (DALL-E, SDXL, Flux)
# Get your token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# LangSmith API Key for tracing and monitoring (optional)
# Get your key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_key_here

# LangSmith Project Name for organizing traces
LANGCHAIN_PROJECT=lunar_tools_art

# LangSmith Tracing (optional - set to 'true' to enable)
LANGCHAIN_TRACING_V2=false

# OpenWeatherMap API Key (for data-driven-cityscape prototype)
# Get your key from: https://openweathermap.org/api
API_KEYS__OPENWEATHERMAP=your_openweathermap_key_here

# Optional: Ollama configuration (alternative to GPT-4)
# LLM__PROVIDER=ollama
# LLM__OLLAMA__MODEL=deepseek-r1:1.5b

# Optional: Logging configuration
# LOGGING__LEVEL=INFO

# Optional: Renderer configuration
# RENDERER__WIDTH=1024
# RENDERER__HEIGHT=768
